# Legal-Ease — Environment Variables
# Copy this to .env for local development.
# On Railway/Render, set these in the dashboard under "Variables".

# ---------------------------------------------------------------
# REQUIRED — Anthropic API key for the AI Legal Assistant.
# Get yours at: https://console.anthropic.com/
# ---------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# ---------------------------------------------------------------
# OPTIONAL — Port the server listens on.
# Railway sets $PORT automatically; you don't need to set this.
# ---------------------------------------------------------------
PORT=3000
